# Local HTTPS template for dev proxy at https://stars.localhost
DATABASE_URL=postgres://postgres:password@localhost:5432/stars_reborn
TEST_DATABASE_URL=postgres://postgres:password@localhost:5432/stars_reborn_test
JWT_SECRET=replace-with-a-random-32-plus-char-secret
# Required: separate pepper used for hashing API tokens.
API_TOKEN_PEPPER=replace-with-a-separate-random-secret
COOKIE_SECURE=true
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_REDIRECT_URL=https://stars.localhost/api/auth/discord/callback
FRONTEND_URL=https://stars.localhost
SERVER_HOST=0.0.0.0
SERVER_PORT=3000
